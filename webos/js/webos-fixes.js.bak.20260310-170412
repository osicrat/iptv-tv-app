      } catch (e) {}

      return hls;
    }

    PatchedHls.prototype = OriginalHls.prototype;

    try {
      var names = Object.getOwnPropertyNames(OriginalHls);
      for (var i = 0; i < names.length; i++) {
        var name = names[i];
        if (name === 'prototype' || name === 'name' || name === 'length') continue;
        var desc = Object.getOwnPropertyDescriptor(OriginalHls, name);
        if (desc) {
          try { Object.defineProperty(PatchedHls, name, desc); } catch (e3) {}
        }
      }
    } catch (e4) {}

    PatchedHls.__etvWebOsPatched = true;
    window.Hls = PatchedHls;
  }

  function armVideoStallGuard(video) {
    if (!video || video.__etvStallGuard) return;
    video.__etvStallGuard = true;

    video.preload = 'auto';
    video.setAttribute('playsinline', 'playsinline');
    video.setAttribute('webkit-playsinline', 'webkit-playsinline');

    var lastProgressTs = Date.now();
    var stallTimer = null;

    function clearStallTimer() {
      if (stallTimer) {
        clearTimeout(stallTimer);
        stallTimer = null;
      }
    }

    function markProgress() {
      lastProgressTs = Date.now();
      clearStallTimer();
    }

    function scheduleRecovery() {
      clearStallTimer();
      stallTimer = setTimeout(function () {
        try {
          if (video.paused || video.ended) return;
          if ((Date.now() - lastProgressTs) < 10000) return;

          video.load();

          var p = video.play();
          if (p && p.catch) {
            p.catch(function () {});
          }
        } catch (e) {}
      }, 12000);
    }

    video.addEventListener('playing', markProgress, false);
    video.addEventListener('canplay', markProgress, false);
    video.addEventListener('timeupdate', markProgress, false);
    video.addEventListener('progress', markProgress, false);
    video.addEventListener('loadeddata', markProgress, false);

    video.addEventListener('waiting', scheduleRecovery, false);
    video.addEventListener('stalled', scheduleRecovery, false);
    video.addEventListener('suspend', scheduleRecovery, false);
    video.addEventListener('error', scheduleRecovery, false);
  }

  function scan() {
    patchHls();

    var videos = document.querySelectorAll('video');
    for (var i = 0; i < videos.length; i++) {
      armVideoStallGuard(videos[i]);
    }
  }

  scan();
  setInterval(scan, 1000);
})();
