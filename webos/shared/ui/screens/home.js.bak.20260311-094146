import { TABS } from '../../utils/constants.js';
import { el, renderList, renderTabs, showToast } from '../components.js';

export function createHomeScreen({ root, state, services }) {
  const tabsNode = el('div', { className: 'tabs' });
  const searchButton = el('button', { className: 'tv-button top-action top-action-search', type: 'button' }, [
    el('span', { className: 'top-action-label' }, 'Busca'),
    el('span', { className: 'top-action-value' }, 'Pesquisar canais'),
  ]);

  const brandBadge = el('div', { className: 'brand-badge' }, [
    el('img', { className: 'brand-badge-logo', src: './assets/appicon.png', alt: 'ETV' }),
  ]);

  const topbar = el('div', { className: 'topbar' }, [
    el('div', { className: 'topbar-left' }, [tabsNode]),
    el('div', { className: 'topbar-right' }, [
      el('div', { className: 'topbar-actions' }, [searchButton]),
      brandBadge,
    ]),
  ]);

  const left = el('div', { className: 'pane pane-left' });
  const right = el('div', { className: 'pane pane-right' });
  const overlay = el('div', { className: 'player-overlay hidden' });

  root.innerHTML = '';
  root.append(topbar, el('div', { className: 'panes' }, [left, right]), overlay);

  const ui = {
    focusList: 'left',
    lastContentFocus: 'left',
    tabIndex: 0,
    topIndex: 0,
    leftIndex: 0,
    rightIndex: 0,
    searchQuery: '',
    isTabLoading: false,
    isPlayerMode: false,
    overlayTimer: null,
    resumeTimer: null,
    lastBackAt: 0,
    wasBackgroundedDuringPlayback: false,
    lastResumeAt: 0,
  };

  state.currentPlayback = state.currentPlayback || null;
  state.currentRightItems = state.currentRightItems || [];
  state.activeTab = state.activeTab || 'Live';

  function clampIndex(index, length) {
    if (!length) return 0;
    return Math.max(0, Math.min(index, length - 1));
  }

  function delay(ms) {
    return new Promise((resolve) => setTimeout(resolve, ms));
  }

  function escapeHtml(value) {
    return String(value || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function isDuplicateBack(windowMs = 350) {
    const now = Date.now();
    if (now - ui.lastBackAt < windowMs) {
      ui.lastBackAt = now;
      return true;
    }
    ui.lastBackAt = now;
    return false;
  }

  function normalizeImageUrl(value) {
    const raw = String(value || '').trim();
    if (!raw) return '';
    if (raw.startsWith('//')) return `https:${raw}`;
    return raw;
  }

  function liveChannelLogoFor(item) {
    return normalizeImageUrl(
      item?.stream_icon || item?.stream_icon_url || item?.streamIcon || item?.channel_logo || item?.logo || item?.icon || ''
    );
  }

  function currentLiveCategory() {
    return (state.liveCategories || [])[ui.leftIndex] || null;
  }

  function currentLiveCategoryId() {
    return currentLiveCategory()?.category_id;
  }

  function currentLiveCategoryName(item = null) {
    const byIndex = currentLiveCategory()?.category_name;
    if (byIndex) return byIndex;
    const categoryId = item?.category_id;
    const match = (state.liveCategories || []).find((entry) => String(entry.category_id) === String(categoryId));
    return match?.category_name || 'Ao vivo';
  }

  function getFilteredLiveStreams() {
    return (state.liveStreams || [])
      .filter((item) => !currentLiveCategoryId() || String(item.category_id) === String(currentLiveCategoryId()))
      .filter((item) => (item.name || '').toLowerCase().includes((ui.searchQuery || '').toLowerCase()));
  }

  function saveLastLiveChannel(item) {
    services.storage.setLastLive?.({
      streamId: item?.stream_id,
      categoryId: currentLiveCategoryId() || item?.category_id || null,
      name: item?.name || '',
      watchedAt: Date.now(),
    });
  }

  function applyLiveSelection(categoryId, streamId, fallbackName = '') {
    const categories = state.liveCategories || [];
    const streams = state.liveStreams || [];

    let categoryIndex = categories.findIndex((c) => String(c.category_id) === String(categoryId));
    if (categoryIndex >= 0) {
      ui.leftIndex = categoryIndex;
      const scoped = streams.filter((s) => String(s.category_id) === String(categoryId));
      const rightIndex = scoped.findIndex((s) => String(s.stream_id) === String(streamId));
      if (rightIndex >= 0) {
        state.currentRightItems = scoped;
        ui.rightIndex = rightIndex;
        ui.focusList = 'right';
        return true;
      }
    }

    const globalMatch = streams.find((s) => String(s.stream_id) === String(streamId) || (fallbackName && s.name === fallbackName));
    if (!globalMatch) return false;

    categoryIndex = categories.findIndex((c) => String(c.category_id) === String(globalMatch.category_id));
    if (categoryIndex < 0) return false;

    ui.leftIndex = categoryIndex;
    const scoped = streams.filter((s) => String(s.category_id) === String(globalMatch.category_id));
    const rightIndex = scoped.findIndex((s) => String(s.stream_id) === String(globalMatch.stream_id));
    if (rightIndex < 0) return false;

    state.currentRightItems = scoped;
    ui.rightIndex = rightIndex;
    ui.focusList = 'right';
    return true;
  }

  function restoreLastLiveSelection() {
    const last = services.storage.getLastLive?.();
    if (!last?.streamId && !last?.name) return false;
    return applyLiveSelection(last.categoryId, last.streamId, last.name || '');
  }


  function setFocusZone(zone) {
    ui.focusList = zone;
    if (zone === 'left' || zone === 'right') ui.lastContentFocus = zone;
  }

  function clampTopIndex(index) {
    return clampIndex(index, 2);
  }

  function syncTopbar() {
    const searchValue = ui.searchQuery ? `Filtrar: ${ui.searchQuery}` : 'Pesquisar canais';
    searchButton.querySelector('.top-action-value').textContent = searchValue;
    const tabButtons = Array.from(tabsNode.querySelectorAll('[data-tab]'));
    tabButtons.forEach((button, idx) => {
      button.classList.toggle('is-focused', ui.focusList === 'tabs' && ui.tabIndex === idx);
    });
    searchButton.classList.toggle('is-focused', ui.focusList === 'top');
    searchButton.classList.toggle('is-active', state.activeTab === 'Live' && !!ui.searchQuery);
  }

  function moveFocusToTabs(preferred = TABS.indexOf(state.activeTab)) {
    ui.tabIndex = clampIndex(preferred >= 0 ? preferred : 0, TABS.length);
    setFocusZone('tabs');
    rerender();
  }

  function getReturnContentZone() {
    if (state.activeTab === 'Config') return 'right';
    if (ui.lastContentFocus === 'right' && currentRightLength() > 0) return 'right';
    return 'left';
  }

  function returnFromTabsToContent() {
    setFocusZone(getReturnContentZone());
    rerender();
  }

  function moveFocusToSearch() {
    setFocusZone('top');
    ui.topIndex = 0;
    rerender();
  }
  async function promptChannelSearch() {
    const nextValue = await new Promise((resolve) => {
      const old = document.getElementById('etv-search-overlay');
      if (old) old.remove();

      const overlay = document.createElement('div');
      overlay.id = 'etv-search-overlay';
      overlay.style.cssText = [
        'position:fixed',
        'inset:0',
        'z-index:99999',
        'display:flex',
        'align-items:center',
        'justify-content:center',
        'background:rgba(5,10,18,.82)'
      ].join(';');

      const box = document.createElement('div');
      box.style.cssText = [
        'width:min(860px,92vw)',
        'padding:24px',
        'border-radius:18px',
        'background:rgba(16,22,34,.96)',
        'border:1px solid rgba(255,255,255,.08)',
        'box-shadow:0 24px 80px rgba(0,0,0,.45)'
      ].join(';');

      const title = document.createElement('div');
      title.textContent = 'Buscar canais';
      title.style.cssText = 'font-size:30px;font-weight:700;margin-bottom:16px;';

      const input = document.createElement('input');
      input.type = 'search';
      input.value = ui.searchQuery || '';
      input.placeholder = 'Digite o nome do canal';
      input.className = 'tv-input';
      input.setAttribute('inputmode', 'search');
      input.setAttribute('enterkeyhint', 'search');
      input.style.cssText = 'width:100%;height:68px;font-size:28px;';

      const actions = document.createElement('div');
      actions.style.cssText = 'display:flex;gap:12px;justify-content:flex-end;margin-top:18px;';

      const clearBtn = document.createElement('button');
      clearBtn.className = 'tv-button';
      clearBtn.textContent = 'Limpar';

      const cancelBtn = document.createElement('button');
      cancelBtn.className = 'tv-button';
      cancelBtn.textContent = 'Cancelar';

      const okBtn = document.createElement('button');
      okBtn.className = 'tv-button primary';
      okBtn.textContent = 'OK';

      function closeWith(value) {
        try { overlay.remove(); } catch (e) {}
        resolve(value);
      }

      function applyValue() {
        closeWith(String(input.value || '').trim());
      }

      function cancelValue() {
        closeWith(null);
      }

      clearBtn.addEventListener('click', () => {
        input.value = '';
        try { input.focus(); } catch (e) {}
        try { input.click(); } catch (e) {}
      });

      cancelBtn.addEventListener('click', () => {
        cancelValue();
      });

      okBtn.addEventListener('click', () => {
        applyValue();
      });

      overlay.addEventListener('keydown', (ev) => {
        const code = ev.which || ev.keyCode || 0;
        if (code === 13) {
          ev.preventDefault();
          ev.stopPropagation();
          applyValue();
          return;
        }
        if (code === 27 || code === 461 || code === 10009) {
          ev.preventDefault();
          ev.stopPropagation();
          cancelValue();
        }
      }, true);

      input.addEventListener('keydown', (ev) => {
        const code = ev.which || ev.keyCode || 0;
        if (code === 13) {
          ev.preventDefault();
          ev.stopPropagation();
          applyValue();
          return;
        }
        if (code === 27 || code === 461 || code === 10009) {
          ev.preventDefault();
          ev.stopPropagation();
          cancelValue();
        }
      }, true);

      actions.appendChild(clearBtn);
      actions.appendChild(cancelBtn);
      actions.appendChild(okBtn);

      box.appendChild(title);
      box.appendChild(input);
      box.appendChild(actions);
      overlay.appendChild(box);
      document.body.appendChild(overlay);

      setTimeout(() => {
        try { input.focus(); } catch (e) {}
        try { input.click(); } catch (e) {}
      }, 60);

      setTimeout(() => {
        try { input.focus(); } catch (e) {}
        try { input.click(); } catch (e) {}
      }, 220);
    });

    if (nextValue === null) return;

    ui.searchQuery = String(nextValue || '').trim();

    try {
      const label = searchButton.querySelector('.top-action-label');
      if (label) label.textContent = ui.searchQuery || 'Buscar';
    } catch (e) {}

    if (typeof render === 'function') {
      render();
    }

    setTimeout(() => {
      try { moveFocusToSearch(); } catch (e) {}
    }, 0);
  }

  async function activateTopAction() {
    await promptChannelSearch();
  }

  function getConfigItems() {
    const settings = services.storage.getSettings();
    return [
      { id: 'toggle-stream', label: `Alternar stream (${settings.streamPreference})` },
      { id: 'clear-cache', label: 'Limpar cache' },
      { id: 'logout', label: 'Logout' },
      { id: 'back-live', label: 'Voltar para canais' },
    ];
  }

  function currentLeftLength() {
    if (state.activeTab === 'Live') return (state.liveCategories || []).length;
    if (state.activeTab === 'Config') return 4;
    return 0;
  }

  function currentRightLength() {
    if (state.activeTab === 'Live') return (state.currentRightItems || []).length;
    if (state.activeTab === 'Config') return getConfigItems().length;
    return 0;
  }

  function clampVisibleIndexes() {
    ui.leftIndex = clampIndex(ui.leftIndex, currentLeftLength());
    ui.rightIndex = clampIndex(ui.rightIndex, currentRightLength());
  }

  function renderLiveChannelRow(item) {
    const name = item?.name || 'Canal';
    const logo = liveChannelLogoFor(item);
    const row = el('div', { className: 'live-channel-row' });
    const logoBox = el('div', { className: `live-channel-logo-box ${logo ? '' : 'is-fallback'}`.trim() });

    if (logo) {
      const img = el('img', {
        className: 'live-channel-logo',
        src: logo,
        alt: name,
        loading: 'lazy',
        referrerpolicy: 'no-referrer',
      });
      img.onerror = () => {
        img.remove();
        logoBox.classList.add('is-fallback');
        logoBox.append(el('div', { className: 'live-channel-logo-fallback' }, name?.slice?.(0, 1) || '•'));
      };
      logoBox.append(img);
    } else {
      logoBox.append(el('div', { className: 'live-channel-logo-fallback' }, name?.slice?.(0, 1) || '•'));
    }

    row.append(logoBox, el('div', { className: 'live-channel-name' }, name));
    return row;
  }

  function renderPaneList(pane, title, items, focusIndex, renderer) {
    pane.innerHTML = '';
    if (title) pane.append(el('div', { className: 'pane-title' }, title));
    const host = el('div', { className: 'pane-list' });
    pane.append(host);
    renderList(host, items, focusIndex >= 0 ? focusIndex : 0, renderer);
    if (focusIndex < 0) {
      host.querySelector('.list-item.is-focused')?.classList.remove('is-focused');
    }
  }

  function renderLive() {
    const categories = state.liveCategories || [];
    const filtered = getFilteredLiveStreams();
    state.currentRightItems = filtered;

    renderPaneList(left, 'Categorias', categories, ui.focusList === 'left' ? ui.leftIndex : -1, (c) => c.category_name);
    renderPaneList(right, 'Canais ao vivo', filtered, ui.focusList === 'right' ? ui.rightIndex : -1, (item) => renderLiveChannelRow(item));
  }

  function renderConfig() {
    const settings = services.storage.getSettings();
    const account = services.session.accountInfo || {};
    const infoItems = [
      { label: 'Conta e sessÃ£o' },
      { label: `Status: ${account.status || '-'}` },
      { label: `Expira em: ${account.exp_date || '-'}` },
      { label: `Stream atual: ${settings.streamPreference}` },
    ];
    const actions = getConfigItems();

    state.currentRightItems = actions;

    renderPaneList(left, 'ConfiguraÃ§Ãµes', infoItems, ui.focusList === 'left' ? ui.leftIndex : -1, (item) => item.label);
    renderPaneList(right, 'AÃ§Ãµes', actions, ui.focusList === 'right' ? ui.rightIndex : -1, (item) => item.label);
  }

  function scheduleOverlayHide(timeoutMs = 3500) {
    if (ui.overlayTimer) clearTimeout(ui.overlayTimer);
    ui.overlayTimer = setTimeout(() => {
      overlay.classList.add('hidden');
      ui.overlayTimer = null;
    }, timeoutMs);
  }

  function showTextOverlay(text, timeoutMs = 3500) {
    overlay.classList.remove('progress-overlay', 'controls-active', 'live-overlay');
    overlay.textContent = text;
    overlay.classList.remove('hidden');
    scheduleOverlayHide(timeoutMs);
  }

  function currentLivePosition(item) {
    const list = state.currentRightItems || [];
    const current = item || list[ui.rightIndex] || null;
    const index = list.findIndex((entry) => String(entry?.stream_id || entry?.id) === String(current?.stream_id || current?.id));
    return {
      item: current,
      index: index >= 0 ? index : ui.rightIndex,
      total: list.length,
    };
  }

  function nowTimeString() {
    return new Date().toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });
  }

  function showLiveOverlay(item, { status = '', timeoutMs = 4500 } = {}) {
    const pos = currentLivePosition(item);
    if (!pos.item) return;

    const info = services.epg?.nowNext?.(pos.item) || {};
    const title = escapeHtml(pos.item.name || 'Canal');
    const category = escapeHtml(currentLiveCategoryName(pos.item));
    const nowTitle = escapeHtml(info.now?.title || 'ProgramaÃ§Ã£o indisponÃ­vel');
    const nextTitle = escapeHtml(info.next?.title || 'Sem PRÓXIMO programa');
    const statusChip = status ? `<span class="player-overlay-chip">${escapeHtml(status)}</span>` : '';

    overlay.classList.add('progress-overlay', 'live-overlay');
    overlay.innerHTML = `
      <div class="player-overlay-panel live-overlay-panel">
        <div class="live-overlay-head">
          <div class="player-overlay-texts">
            <div class="player-overlay-title">${title}</div>
            <div class="player-overlay-meta">${category} • Canal ${pos.index + 1}/${Math.max(1, pos.total)}</div>
          </div>
          <div class="live-overlay-badges">
            <span class="player-overlay-chip player-overlay-chip-primary">AO VIVO</span>
            ${statusChip}
            <span class="player-overlay-chip">${escapeHtml(nowTimeString())}</span>
          </div>
        </div>
        <div class="live-overlay-programs">
          <div class="live-overlay-program-card is-now">
            <div class="live-overlay-label">Agora</div>
            <div class="live-overlay-program-title">${nowTitle}</div>
          </div>
          <div class="live-overlay-program-card">
            <div class="live-overlay-label">PRÓXIMO</div>
            <div class="live-overlay-program-title">${nextTitle}</div>
          </div>
        </div>
        <div class="player-overlay-hint">INFO ou OK detalhes • â–²â–¼ / CH± trocam canal • BACK volta</div>
      </div>
    `;
    overlay.classList.remove('hidden');
    scheduleOverlayHide(timeoutMs);
  }

  async function showLiveOverlayWithEpg(item, opts = {}) {
    const status = opts?.status || '';
    showLiveOverlay(item, { status: status || 'Carregando guia', timeoutMs: opts.timeoutMs || 4500 });
    try {
      await services.ensureEpg();
    } catch (err) {
      console.warn('EPG indisponÃ­vel para overlay:', err);
    }
    showLiveOverlay(item, opts);
  }

  function enterPlayerMode() {
    ui.isPlayerMode = true;
    root.classList.add('player-mode');
  }

  function exitPlayerMode({ stopPlayback = true } = {}) {
    ui.isPlayerMode = false;
    root.classList.remove('player-mode');
    if (stopPlayback) services.stopPlayback?.();
    overlay.classList.add('hidden');
    if (ui.overlayTimer) {
      clearTimeout(ui.overlayTimer);
      ui.overlayTimer = null;
    }
    if (ui.resumeTimer) {
      clearTimeout(ui.resumeTimer);
      ui.resumeTimer = null;
    }
    ui.wasBackgroundedDuringPlayback = false;
  }

  function setCurrentPlayback(partial) {
    state.currentPlayback = { ...(state.currentPlayback || {}), ...partial };
  }

  async function playCurrentLiveByIndex(index) {
    const items = state.currentRightItems || [];
    if (!items.length) return;

    ui.rightIndex = ((index % items.length) + items.length) % items.length;
    const item = items[ui.rightIndex];
    if (!item) return;

    saveLastLiveChannel(item);
    setCurrentPlayback({
      kind: 'live',
      title: item.name || 'Canal',
      subtitle: 'Ao vivo',
      meta: `${ui.rightIndex + 1}/${items.length}`,
      next: '',
      isLive: true,
      paused: false,
      item,
      categoryName: currentLiveCategoryName(item),
    });

    const candidates = services.client.buildStreamCandidates('live', item);
    services.play(item, candidates, {
      isLive: true,
      kind: 'live',
      recent: {
        id: item.stream_id || item.id,
        type: 'live',
        kind: 'live',
        name: item.name || 'Canal',
        item,
      },
    });

    enterPlayerMode();
    await showLiveOverlayWithEpg(item, { status: 'Conectando...', timeoutMs: 4500 });
  }

  async function zapLive(step) {
    if (state.activeTab !== 'Live') return;
    const items = state.currentRightItems || [];
    if (!items.length) return;
    await playCurrentLiveByIndex(ui.rightIndex + step);
  }

  async function openCurrent() {
    const item = state.currentRightItems?.[ui.rightIndex];
    if (!item) return;
    if (state.activeTab === 'Live') await playCurrentLiveByIndex(ui.rightIndex);
  }

  async function runConfigAction(actionId) {
    if (actionId === 'toggle-stream') {
      const settings = services.storage.getSettings();
      const next = settings.streamPreference === 'hls-first' ? 'ts-first' : 'hls-first';
      services.storage.setSettings({ streamPreference: next });
      showToast(`PreferÃªncia alterada para ${next}`);
      await loadTab('Config', { autoplayLastLive: false });
      ui.focusList = 'right';
      ui.rightIndex = 0;
      rerender();
      return;
    }

    if (actionId === 'clear-cache') {
      services.storage.clearCache();
      showToast('Cache limpo');
      return;
    }

    if (actionId === 'logout') {
      await services.logout?.();
      return;
    }

    if (actionId === 'back-live') {
      await switchTab('Live');
    }
  }

  async function loadTab(tab, { autoplayLastLive = tab === 'Live' } = {}) {
    ui.isTabLoading = true;
    state.activeTab = tab;
    ui.leftIndex = 0;
    ui.rightIndex = 0;
    setFocusZone(tab === 'Config' ? 'right' : 'left');
    renderTabs(tabsNode, TABS, tab);

    let restoredLive = false;
    try {
      if (tab === 'Live') {
        state.liveCategories = await services.client.getLiveCategories();
        state.liveStreams = await services.client.getLiveStreams();
        restoredLive = restoreLastLiveSelection();
        renderLive();
      } else {
        renderConfig();
      }
    } finally {
      ui.isTabLoading = false;
    }

    syncTopbar();

    if (tab === 'Live' && autoplayLastLive && restoredLive && !ui.isPlayerMode) {
      setTimeout(() => {
        if (state.activeTab === 'Live' && !ui.isPlayerMode) openCurrent();
      }, 0);
    }
  }

  async function switchTab(tab) {
    ui.tabIndex = Math.max(0, TABS.indexOf(tab));
    exitPlayerMode();
    await loadTab(tab, { autoplayLastLive: true });
  }

  function rerender() {
    clampVisibleIndexes();
    syncTopbar();
    if (state.activeTab === 'Live') renderLive();
    else renderConfig();
  }

  tabsNode.addEventListener('click', (ev) => {
    const button = ev.target.closest('[data-tab]');
    if (!button) return;
    const tab = button.getAttribute('data-tab');
    ui.tabIndex = Math.max(0, TABS.indexOf(tab));
    switchTab(tab);
  });

  searchButton.addEventListener('click', async () => {
    moveFocusToSearch();
    await activateTopAction();
  });

  right.addEventListener('click', (ev) => {
    const row = ev.target.closest('.list-item[data-index]');
    if (!row) return;

    setFocusZone('right');
    ui.rightIndex = Number(row.getAttribute('data-index'));

    if (state.activeTab === 'Live') {
      if (!ui.isTabLoading) openCurrent();
    } else if (state.activeTab === 'Config') {
      const action = getConfigItems()[ui.rightIndex];
      if (action) runConfigAction(action.id);
    }

    rerender();
  });

  left.addEventListener('click', (ev) => {
    const row = ev.target.closest('.list-item[data-index]');
    if (!row) return;

    setFocusZone('left');
    ui.leftIndex = Number(row.getAttribute('data-index'));

    if (state.activeTab === 'Live') ui.rightIndex = 0;
    rerender();
  });

  function currentLiveItemForResume() {
    const current = state.currentPlayback?.item;
    if (current) return current;
    return (state.currentRightItems || [])[ui.rightIndex] || null;
  }

  function currentLiveIndexForItem(item) {
    const items = state.currentRightItems || [];
    if (!item) return ui.rightIndex;
    const byStreamId = items.findIndex((entry) => String(entry?.stream_id || entry?.id) === String(item?.stream_id || item?.id));
    return byStreamId >= 0 ? byStreamId : ui.rightIndex;
  }

  function onAppHidden() {
    ui.wasBackgroundedDuringPlayback = !!(ui.isPlayerMode && state.currentPlayback?.isLive);
    if (ui.resumeTimer) {
      clearTimeout(ui.resumeTimer);
      ui.resumeTimer = null;
    }
  }

  async function onAppResume() {
    if (document.hidden) return;
    if (!ui.wasBackgroundedDuringPlayback) return;
    const now = Date.now();
    if (now - ui.lastResumeAt < 1200) return;
    ui.lastResumeAt = now;

    const item = currentLiveItemForResume();
    if (!item) {
      ui.wasBackgroundedDuringPlayback = false;
      return;
    }

    const resumeIndex = currentLiveIndexForItem(item);
    ui.wasBackgroundedDuringPlayback = false;

    if (ui.resumeTimer) clearTimeout(ui.resumeTimer);
    ui.resumeTimer = setTimeout(async () => {
      ui.resumeTimer = null;
      if (state.activeTab !== 'Live') return;
      try {
        services.stopPlayback?.();
        await delay(180);
        await showLiveOverlayWithEpg(item, { status: 'Retomando...', timeoutMs: 5000 });
        await playCurrentLiveByIndex(resumeIndex);
      } catch (err) {
        console.warn('Falha ao retomar live após voltar ao app:', err);
      }
    }, 350);
  }

  async function onPlaybackEnded() {
    if (!ui.isPlayerMode) return;
    if (state.currentPlayback?.isLive) {
      showLiveOverlay(state.currentPlayback?.item, { status: 'Transmissão encerrada', timeoutMs: 3000 });
      return;
    }
    showTextOverlay('Transmissão encerrada', 2500);
  }

  function onPlaybackStarted(meta = {}) {
    if (!ui.isPlayerMode || !state.currentPlayback?.isLive) return;
    showLiveOverlay(meta.item || state.currentPlayback?.item, { status: 'Conectado', timeoutMs: 3000 });
  }

  function onPlaybackReconnect(meta = {}) {
    if (!ui.isPlayerMode || !state.currentPlayback?.isLive) return;
    showLiveOverlay(meta.item || state.currentPlayback?.item, {
      status: `Reconectando ${meta.attempt || 1}/${meta.max || 1}`,
      timeoutMs: 5000,
    });
  }

  function onPlaybackError(meta = {}) {
    const message = state.currentPlayback?.isLive
      ? 'Falha ao reproduzir o canal'
      : 'Falha na reprodução';
    showTextOverlay(message, 3200);
    console.warn('Playback error:', meta);
  }

  function onKey(key) {
    if (key === 'Back' && isDuplicateBack()) return;
    if (TABS.includes(key)) return switchTab(key);

    const isLeft = key === 'ArrowLeft' || key === 'Left';
    const isRight = key === 'ArrowRight' || key === 'Right';
    const isUp = key === 'ArrowUp' || key === 'Up';
    const isDown = key === 'ArrowDown' || key === 'Down';

    if (ui.isPlayerMode) {
      if (key === 'Back') {
        ui.searchQuery = '';
        try {
          const label = searchButton.querySelector('.top-action-label');
          if (label) label.textContent = 'Buscar';
        } catch (e) {}
        exitPlayerMode();
        rerender();
        return;
      }

      if (state.activeTab === 'Live' && (isUp || key === 'ChannelUp')) {
        zapLive(-1);
        return;
      }

      if (state.activeTab === 'Live' && (isDown || key === 'ChannelDown')) {
        zapLive(1);
        return;
      }

      if (key === 'Info' || key === 'Enter' || key === 'Play' || key === 'PlayPause' || isLeft || isRight) {
        const item = (state.currentRightItems || [])[ui.rightIndex] || state.currentPlayback?.item;
        if (item) showLiveOverlayWithEpg(item, { status: 'Ao vivo', timeoutMs: 4500 });
        return;
      }

      return;
    }

    if (key === 'Search') {
      moveFocusToSearch();
      promptChannelSearch();
      return;
    }

    if (key === 'Back') {
      if (ui.focusList !== 'tabs') {
        moveFocusToTabs();
      }
      return;
    }

    if (ui.focusList === 'tabs') {
      if (isLeft) {
        ui.tabIndex = clampIndex(ui.tabIndex - 1, TABS.length);
        syncTopbar();
        return;
      }

      if (isRight) {
        if (ui.tabIndex >= TABS.length - 1) {
          moveFocusToSearch();
          return;
        }
        ui.tabIndex = clampIndex(ui.tabIndex + 1, TABS.length);
        syncTopbar();
        return;
      }

      if (isDown) {
        returnFromTabsToContent();
        return;
      }

      if (key === 'Enter') {
        const nextTab = TABS[ui.tabIndex] || 'Live';
        switchTab(nextTab);
        return;
      }

      return;
    }

    if (ui.focusList === 'top') {
      if (isLeft) {
        moveFocusToTabs(TABS.length - 1);
        return;
      }

      if (isDown) {
        returnFromTabsToContent();
        return;
      }

      if (key === 'Enter') {
        activateTopAction();
        return;
      }

      return;
    }

    if (state.activeTab === 'Config') {
      if (isLeft) {
        setFocusZone('left');
        rerender();
        return;
      }

      if (isRight) {
        setFocusZone('right');
        rerender();
        return;
      }

      if (isUp) {
        if (ui.focusList === 'left') {
          if (ui.leftIndex <= 0) {
            moveFocusToTabs(1);
            return;
          }
          ui.leftIndex = clampIndex(ui.leftIndex - 1, currentLeftLength());
        } else {
          if (ui.rightIndex <= 0) {
            moveFocusToTabs(1);
            return;
          }
          ui.rightIndex = clampIndex(ui.rightIndex - 1, currentRightLength());
        }
        rerender();
        return;
      }

      if (isDown) {
        if (ui.focusList === 'left') ui.leftIndex = clampIndex(ui.leftIndex + 1, currentLeftLength());
        else ui.rightIndex = clampIndex(ui.rightIndex + 1, currentRightLength());
        rerender();
        return;
      }

      if (key === 'Enter') {
        if (ui.focusList === 'left') {
          setFocusZone('right');
          rerender();
          return;
        }

        const action = getConfigItems()[ui.rightIndex];
        if (action) runConfigAction(action.id);
        return;
      }

      return;
    }

    if (isLeft) {
      setFocusZone('left');
      rerender();
      return;
    }

    if (isRight) {
      setFocusZone('right');
      rerender();
      return;
    }

    if (isUp) {
      if (ui.focusList === 'left') {
        if (ui.leftIndex <= 0) {
          moveFocusToTabs(0);
          return;
        }
        ui.leftIndex = clampIndex(ui.leftIndex - 1, currentLeftLength());
      } else {
        if (ui.rightIndex <= 0) {
          moveFocusToTabs(0);
          return;
        }
        ui.rightIndex = clampIndex(ui.rightIndex - 1, currentRightLength());
      }
      rerender();
      return;
    }

    if (isDown) {
      if (ui.focusList === 'left') ui.leftIndex = clampIndex(ui.leftIndex + 1, currentLeftLength());
      else ui.rightIndex = clampIndex(ui.rightIndex + 1, currentRightLength());
      rerender();
      return;
    }

    if (key === 'Enter') {
      if (ui.focusList === 'left') {
        setFocusZone('right');
        ui.rightIndex = 0;
        rerender();
        return;
      }

      if (ui.focusList === 'right' && !ui.isTabLoading) {
        openCurrent();
        return;
      }
    }

    rerender();
  }

  loadTab('Live', { autoplayLastLive: true });

  return {
    onKey,
    onPlaybackEnded,
    onPlaybackStarted,
    onPlaybackReconnect,
    onPlaybackError,
    onAppHidden,
    onAppResume,
    showOverlay(content) {
      showTextOverlay(content);
    },
    showPlaybackOverlay(content) {
      if (typeof content === 'string') showTextOverlay(content);
    },
    hideOverlay() {
      overlay.classList.add('hidden');
    },
    exitPlayerMode,
  };
}



