<?xml version="1.0" encoding="utf-8" ?>
<component name="PlayerScreen" extends="Group">
    <interface>
        <field id="backRequested" type="boolean" alwaysNotify="true" />
    </interface>
    <script type="text/brightscript" uri="pkg:/components/screens/PlayerScreen.brs" />
    <children>
        <Rectangle width="1280" height="720" color="0x000000FF" />
        <Video id="video" width="1280" height="720" translation="[0,0]" />

        <Group id="overlay" visible="true">
            <Rectangle width="1280" height="110" translation="[0,0]" color="0x000000B3" />
            <Label id="title" translation="[24,18]" color="0xFFFFFFFF" text="" />
            <Label id="subtitle" translation="[24,52]" color="0x9EB6D8FF" text="Ao vivo" />
            <Label id="hint" translation="[24,80]" color="0x9EB6D8FF" text="Info: detalhes • Back: voltar" />
        </Group>

        <Timer id="overlayTimer" duration="4" repeat="false" />
    </children>
</component>
